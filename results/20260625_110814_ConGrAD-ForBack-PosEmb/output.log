  (co_attn): ModuleList(
    (0-1): 2 x CoAttentionBlock(
      (audio_attn): MultiheadAttention(
        (out_proj): NonDynamicallyQuantizableLinear(in_features=128, out_features=128, bias=True)
      )
      (text_attn): MultiheadAttention(
        (out_proj): NonDynamicallyQuantizableLinear(in_features=128, out_features=128, bias=True)
      )
      (ffn_a): Sequential(
        (0): Linear(in_features=128, out_features=512, bias=True)
        (1): GELU(approximate='none')
        (2): Dropout(p=0.5, inplace=False)
        (3): Linear(in_features=512, out_features=128, bias=True)
      )
      (ffn_t): Sequential(
        (0): Linear(in_features=128, out_features=512, bias=True)
        (1): GELU(approximate='none')
        (2): Dropout(p=0.5, inplace=False)
        (3): Linear(in_features=512, out_features=128, bias=True)
      )
      (norm_a1): LayerNorm((128,), eps=1e-05, elementwise_affine=True)
      (norm_t1): LayerNorm((128,), eps=1e-05, elementwise_affine=True)
      (norm_a2): LayerNorm((128,), eps=1e-05, elementwise_affine=True)
      (norm_t2): LayerNorm((128,), eps=1e-05, elementwise_affine=True)
    )
  )
  (fusion): Linear(in_features=256, out_features=128, bias=True)
  (rgat): RGAT(
    (layers): ModuleList(
      (0-1): 2 x RGATConv(128, 32, heads=4)
    )
    (drop): Dropout(p=0.5, inplace=False)
  )
  (att_score): Linear(in_features=256, out_features=1, bias=True)
  (classifier): Sequential(
    (0): Linear(in_features=256, out_features=128, bias=True)
    (1): GELU(approximate='none')
    (2): Dropout(p=0.5, inplace=False)
    (3): Linear(in_features=128, out_features=3, bias=True)
  )
